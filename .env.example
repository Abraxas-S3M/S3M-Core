# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=s3m
DB_USER=s3m_user
DB_PASS=

# Cloudflare R2
R2_BUCKET=s3m-vault
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=

# RunPod
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Pipeline
S3M_ENV=production
S3M_ROOT=/opt/s3m
INBOX_DIR=/opt/s3m/state/training/cloud_cpu/inbox
PACKETS_DIR=/opt/s3m/packets
STAGING_DIR=/opt/s3m/state/training/staging
LOG_DIR=/opt/s3m/logs
POLL_INTERVAL=10
EXAMPLES_PER_PACK=50
