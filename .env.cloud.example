# S3M Cloud CPU Demo — Environment Configuration
# Copy to .env.cloud and fill in real values. NEVER commit .env.cloud to git.

# ── Deployment Mode ──────────────────────────────────────────
DEPLOYMENT_MODE=cloud_cpu_demo
S3M_DEVICE=cpu

# ── Server ───────────────────────────────────────────────────
S3M_HOST=0.0.0.0
S3M_PORT=8080
S3M_WORKERS=1
S3M_LOG_LEVEL=info

# ── Authentication ───────────────────────────────────────────
S3M_AUTH_ENABLED=true
S3M_API_KEY=CHANGE_ME_TO_A_STRONG_SECRET

# ── CORS — Cloudflare Pages frontend domain(s) ──────────────
CORS_ORIGINS=https://demo.yourdomain.com,https://staging-demo.yourdomain.com

# ── CPU Threading ────────────────────────────────────────────
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8
OPENBLAS_NUM_THREADS=8
NUMEXPR_NUM_THREADS=8

# ── Paths (inside container) ────────────────────────────────
S3M_MODEL_DIR=/opt/s3m/models
S3M_DATA_DIR=/opt/s3m/data
S3M_CHECKPOINT_DIR=/opt/s3m/data/checkpoints

# ── Worker ───────────────────────────────────────────────────
S3M_WORKER_INTERVAL_SECONDS=300

# ── GUI Bridge (for Cloudflare Pages frontend) ──────────────
VITE_API_BASE_URL=https://api.yourdomain.com/api/v1
VITE_WS_URL=wss://api.yourdomain.com/ws
